# ─────────────────────────────────────────────────────────────
# PreventAI Frontend – Environment Variables
# Copy to .env and fill in your values.
# ─────────────────────────────────────────────────────────────

# URL of the Python FastAPI backend (ML + AI insights)
# Default: http://localhost:8000
VITE_API_URL=http://localhost:8000

# JWT secret used by the Node.js auth server (server.ts)
# Must match JWT_SECRET in backend .env
JWT_SECRET=preventai-super-secret-key
