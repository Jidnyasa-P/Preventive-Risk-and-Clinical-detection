# ─────────────────────────────────────────────────────────
# PreventAI Backend - Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────

# LLM Provider: "gemini" (default) or "openai"
LLM_PROVIDER=gemini

# Your API Key:
#   Gemini: get from https://aistudio.google.com/app/apikey
#   OpenAI: get from https://platform.openai.com/api-keys
LLM_API_KEY=your_api_key_here

# Model override (optional - leave blank to auto-detect)
# Gemini options: gemini-2.0-flash, gemini-1.5-pro, gemini-1.5-flash
# OpenAI options: gpt-4o-mini, gpt-4o, gpt-3.5-turbo
LLM_MODEL=

# ML model path (default: diabetes_model.pkl in same directory)
MODEL_PATH=diabetes_model.pkl

# Dataset path for retraining (default: diabetes_dataset.csv)
DATASET_PATH=diabetes_dataset.csv

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000
