# ─────────────────────────────────────────────────────────────
# PreventAI Backend – Environment Variables
# Copy to .env and fill in your values.
# ─────────────────────────────────────────────────────────────

# ── LLM Configuration ────────────────────────────────────────
# Choose "openai" or "gemini"
LLM_PROVIDER=gemini

# Your API key for the chosen provider
LLM_API_KEY=""

# (Optional) Override the default model
# OpenAI default : gpt-4o-mini
Gemini default : gemini-1.5-flash
# LLM_MODEL=gpt-4o

# ── Model & Dataset ──────────────────────────────────────────
# Path to the pre-trained .pkl file
# If missing, the server auto-trains from DATASET_PATH
MODEL_PATH=diabetes_model.pkl

# Path to CSV dataset (only used if MODEL_PATH is missing)
DATASET_PATH=diabetes_dataset.csv

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Server ───────────────────────────────────────────────────
# HOST=0.0.0.0
# PORT=8000